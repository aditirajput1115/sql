-- Table creation
CREATE TABLE Account (
    Account_No NUMBER PRIMARY KEY,
    Cust_Name VARCHAR2(50),
    Balance NUMBER,
    NoOfYears NUMBER
);

CREATE TABLE Earned_Interest (
    Account_No NUMBER,
    Interest_Amt NUMBER
);

-- 1. Procedure to calculate and store simple interest
CREATE OR REPLACE PROCEDURE calc_interest (
    p_acc_no IN NUMBER,
    p_rate   IN NUMBER
)
IS
    v_balance Account.Balance%TYPE;
    v_years   Account.NoOfYears%TYPE;
    v_interest NUMBER;
BEGIN
    SELECT Balance, NoOfYears INTO v_balance, v_years
    FROM Account
    WHERE Account_No = p_acc_no;

    v_interest := (v_balance * p_rate * v_years) / 100;

    INSERT INTO Earned_Interest(Account_No, Interest_Amt)
    VALUES (p_acc_no, v_interest);

    DBMS_OUTPUT.PUT_LINE('--- Earned Interest Table ---');
    FOR rec IN (SELECT * FROM Earned_Interest) LOOP
        DBMS_OUTPUT.PUT_LINE('Acc No: ' || rec.Account_No ||
                             ' Interest: ' || rec.Interest_Amt);
    END LOOP;
END;
/

-- 2. Function to display accounts with balance > 50000
CREATE OR REPLACE FUNCTION get_high_balance
RETURN SYS_REFCURSOR
IS
    cur SYS_REFCURSOR;
BEGIN
    OPEN cur FOR
        SELECT * FROM Account WHERE Balance > 50000;
    RETURN cur;
END;
/

