-- Table creation
CREATE TABLE Products (
    Product_id NUMBER PRIMARY KEY,
    Product_Name VARCHAR2(50),
    Product_Type VARCHAR2(50),
    Price NUMBER
);

-- 1. Parameterized cursor (price range & Apparel type)
DECLARE
    v_min NUMBER := &min_price;
    v_max NUMBER := &max_price;

    CURSOR prod_cursor(p_min NUMBER, p_max NUMBER) IS
        SELECT * FROM Products
        WHERE Price BETWEEN p_min AND p_max
        AND Product_Type = 'Apparel';

    rec Products%ROWTYPE;
BEGIN
    OPEN prod_cursor(v_min, v_max);
    LOOP
        FETCH prod_cursor INTO rec;
        EXIT WHEN prod_cursor%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE(rec.Product_id || ' ' || rec.Product_Name || ' ' || rec.Price);
    END LOOP;
    CLOSE prod_cursor;
END;
/

-- 2. Explicit cursor (Price > 5000)
DECLARE
    CURSOR c1 IS
        SELECT * FROM Products WHERE Price > 5000;

    rec Products%ROWTYPE;
BEGIN
    OPEN c1;
    LOOP
        FETCH c1 INTO rec;
        EXIT WHEN c1%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE(rec.Product_id || ' ' || rec.Product_Name || ' ' || rec.Price);
    END LOOP;
    CLOSE c1;
END;
/

-- 3. Implicit cursor (update price +1000)
BEGIN
    UPDATE Products
    SET Price = Price + 1000;

    DBMS_OUTPUT.PUT_LINE('Rows Updated: ' || SQL%ROWCOUNT);
END;
/
