{Roll_No:"A2", Name:"Neha", Class:"SE", Marks:60, Address:"Mumbai", Enrolled_Courses:["CN","DBMS"]},
{Roll_No:"A3", Name:"Raj", Class:"TE", Marks:90, Address:"Nashik", Enrolled_Courses:["TOC","OS"]},
{Roll_No:"A4", Name:"Simran", Class:"FE", Marks:45, Address:"Pune", Enrolled_Courses:["DBMS"]},
{Roll_No:"A5", Name:"Karan", Class:"SE", Marks:30, Address:"Nagpur", Enrolled_Courses:["TOC"]},
{Roll_No:"A6", Name:"Pooja", Class:"TE", Marks:95, Address:"Pune", Enrolled_Courses:["DBMS","TOC","CN"]},
{Roll_No:"A7", Name:"Ravi", Class:"FE", Marks:20, Address:"Mumbai", Enrolled_Courses:["CN"]},
