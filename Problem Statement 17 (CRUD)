])

// 1. Students enrolled in DBMS and TOC
db.Student.find({Enrolled_Courses: {$all: ["DBMS","TOC"]}}, {Name:1, _id:0})

// 2. Roll_No and Class where marks > 50 OR Class = TE
db.Student.find(
  {$or: [{Marks: {$gt: 50}}, {Class: "TE"}]},
  {Roll_No:1, Class:1, _id:0}
)

// 3. Update entire record of Roll_No A10
db.Student.replaceOne(
  {Roll_No: "A10"},
  {Roll_No:"A10", Name:"Updated", Class:"TE", Marks:80, Address:"Mumbai", Enrolled_Courses:["DBMS","CN"]}
)

// 4. Names of students with 3rd and 4th highest marks
db.Student.find({}, {Name:1, Marks:1, _id:0})
.sort({Marks:-1})
.skip(2)
.limit(2)

// 5. Delete students with marks < 20
db.Student.deleteMany({Marks: {$lt: 20}})

// 6. Delete first record from collection
db.Student.deleteOne({})
