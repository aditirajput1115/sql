-- Table creation
CREATE TABLE Employee (
    emp_id NUMBER PRIMARY KEY,
    emp_name VARCHAR2(50),
    dept_id NUMBER,
    DoJ DATE,
    salary NUMBER,
    commission NUMBER,
    job_title VARCHAR2(50)
);

CREATE TABLE Salary_Increment (
    emp_id NUMBER,
    new_salary NUMBER
);

-- Unnamed PL/SQL Block
DECLARE
    v_emp_id NUMBER := &emp_id;
    v_salary Employee.salary%TYPE;
    v_doj Employee.DoJ%TYPE;
    v_exp NUMBER;
    v_new_salary NUMBER;

    ex_emp_not_found EXCEPTION;
BEGIN
    -- Fetch employee details
    SELECT salary, DoJ INTO v_salary, v_doj
    FROM Employee
    WHERE emp_id = v_emp_id;

    -- Calculate experience in years
    v_exp := FLOOR(MONTHS_BETWEEN(SYSDATE, v_doj)/12);

    -- Salary increment logic
    IF v_exp > 10 THEN
        v_new_salary := v_salary + (v_salary * 0.20);
    ELSIF v_exp > 5 THEN
        v_new_salary := v_salary + (v_salary * 0.10);
    ELSE
        v_new_salary := v_salary + (v_salary * 0.05);
    END IF;

    -- Insert into Salary_Increment table
    INSERT INTO Salary_Increment(emp_id, new_salary)
    VALUES (v_emp_id, v_new_salary);

    DBMS_OUTPUT.PUT_LINE('New Salary: ' || v_new_salary);

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RAISE ex_emp_not_found;

    WHEN ex_emp_not_found THEN
        DBMS_OUTPUT.PUT_LINE('Employee not found');

    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Error occurred: ' || SQLERRM);
END;
/
