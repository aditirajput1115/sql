-- Table creation
CREATE TABLE Employee (
    Emp_id NUMBER PRIMARY KEY,
    Emp_Name VARCHAR2(50),
    Salary NUMBER
);

-- 1. Explicit cursor (Salary > 50000)
DECLARE
    CURSOR c1 IS
        SELECT * FROM Employee WHERE Salary > 50000;

    rec Employee%ROWTYPE;
BEGIN
    OPEN c1;
    LOOP
        FETCH c1 INTO rec;
        EXIT WHEN c1%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE(rec.Emp_id || ' ' || rec.Emp_Name || ' ' || rec.Salary);
    END LOOP;
    CLOSE c1;
END;
/

-- 2. Implicit cursor (count total tuples)
DECLARE
    v_count NUMBER;
BEGIN
    SELECT COUNT(*) INTO v_count FROM Employee;

    DBMS_OUTPUT.PUT_LINE('Total Records: ' || v_count);
END;
/

-- 3. Parameterized cursor (salary by Emp_id)
DECLARE
    v_id NUMBER := &emp_id;

    CURSOR c2(p_id NUMBER) IS
        SELECT Salary FROM Employee WHERE Emp_id = p_id;

    v_salary NUMBER;
BEGIN
    OPEN c2(v_id);
    FETCH c2 INTO v_salary;

    IF c2%FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Salary: ' || v_salary);
    ELSE
        DBMS_OUTPUT.PUT_LINE('Employee not found');
    END IF;

    CLOSE c2;
END;
/
